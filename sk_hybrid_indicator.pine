//
// ===== CHANGELOG =====
// v1.0.0 (2025-08-29) - Základ: 4x MA (EMA/SMA) + VWAP (ta.vwap property)
// v1.1.0 (2026-04-02) - VWAP Band s multiplikátorom (StdDev / Percentage)
//                      - Source a Hide on 1D+ pre VWAP
//                      - Bilingválne labels (SK/EN)
//                      - Farba/hrúbka presunutá do Style tab
//                      - Oprava: VWAP ciara pouziva ta.vwap property (zhodna s TV VWAP)
//                      - Oprava: fill() color chyba CE10123
//                      - Oprava: shorttitle limit 10 znakov
// ======================

//@version=6
indicator("Slovak Hybrid (VWAP, Multi MA)", "JS VWAP/MA", true, timeframe="", timeframe_gaps=true)

// --- GENERAL SETTINGS / VŠEOBECNÉ NASTAVENIA ---
string group_ma   = "Moving Averages (MA)"
string group_vwap = "VWAP"
string group_band = "VWAP Band / Pás"

// =============================================
// MOVING AVERAGES
// =============================================
show_ma_group = input.bool(true, "Show MA / Zobraziť MA", group = group_ma)

// MA 1
show_ma1  = input.bool(true, "MA 1", group = group_ma, inline = "ma1")
ma1_type  = input.string("EMA", "", options = ["EMA", "SMA"], group = group_ma, inline = "ma1")
ma1_len   = input.int(20, "Length / Dĺžka", group = group_ma, inline = "ma1")
ma1_src   = input.source(close, "Source / Zdroj", group = group_ma, inline = "ma1")

// MA 2
show_ma2  = input.bool(true, "MA 2", group = group_ma, inline = "ma2")
ma2_type  = input.string("EMA", "", options = ["EMA", "SMA"], group = group_ma, inline = "ma2")
ma2_len   = input.int(50, "Length / Dĺžka", group = group_ma, inline = "ma2")
ma2_src   = input.source(close, "Source / Zdroj", group = group_ma, inline = "ma2")

// MA 3
show_ma3  = input.bool(true, "MA 3", group = group_ma, inline = "ma3")
ma3_type  = input.string("SMA", "", options = ["EMA", "SMA"], group = group_ma, inline = "ma3")
ma3_len   = input.int(100, "Length / Dĺžka", group = group_ma, inline = "ma3")
ma3_src   = input.source(close, "Source / Zdroj", group = group_ma, inline = "ma3")

// MA 4
show_ma4  = input.bool(true, "MA 4", group = group_ma, inline = "ma4")
ma4_type  = input.string("SMA", "", options = ["EMA", "SMA"], group = group_ma, inline = "ma4")
ma4_len   = input.int(200, "Length / Dĺžka", group = group_ma, inline = "ma4")
ma4_src   = input.source(close, "Source / Zdroj", group = group_ma, inline = "ma4")

// =============================================
// VWAP
// =============================================
show_vwap    = input.bool(true, "Show VWAP / Zobraziť VWAP", group = group_vwap)
vwap_src     = input.source(hlc3, "Source / Zdroj", group = group_vwap)
hideonDWM    = input.bool(false, "Hide on 1D+ / Skryť na 1D+", group = group_vwap)

// =============================================
// VWAP BAND / PÁS
// =============================================
CALC_MODE_TIP = "Standard Deviation = absolute deviation from VWAP. Percentage = 1 multiplier means 1%."
show_band     = input.bool(false, "Show Band / Zobraziť pás", group = group_band, inline = "band1")
bandMult      = input.float(1.0, "Multiplier / Multiplikátor", group = group_band, inline = "band1", step = 0.5, minval = 0)
calcMode      = input.string("Standard Deviation", "Mode / Režim", options = ["Standard Deviation", "Percentage"], group = group_band, tooltip = CALC_MODE_TIP)

// =============================================
// CALCULATIONS / VÝPOČTY
// =============================================

// --- MA calculation ---
f_ma(source, length, type) =>
    float result = na
    if type == "EMA"
        result := ta.ema(source, length)
    else if type == "SMA"
        result := ta.sma(source, length)
    result

ma1 = show_ma1 and show_ma_group ? f_ma(ma1_src, ma1_len, ma1_type) : na
ma2 = show_ma2 and show_ma_group ? f_ma(ma2_src, ma2_len, ma2_type) : na
ma3 = show_ma3 and show_ma_group ? f_ma(ma3_src, ma3_len, ma3_type) : na
ma4 = show_ma4 and show_ma_group ? f_ma(ma4_src, ma4_len, ma4_type) : na

// --- VWAP + Band calculation ---

// ta.vwap property — identicky s TV vestavanym VWAP indikatorom (overene v1.0)
hideVwap = hideonDWM and timeframe.isdwm
float vwapValue      = show_vwap and not hideVwap ? ta.vwap : na
float upperBandValue = na
float lowerBandValue = na

// Pas: ta.vwap() funkcia sa pouziva IBA na ziskanie stdev — VWAP ciara ostava ta.vwap property
if show_band and not na(vwapValue)
    [_vwap_func, _stdevUpper, _] = ta.vwap(vwap_src, timeframe.change("D"), 1)
    stdevAbs  = _stdevUpper - _vwap_func
    bandBasis = calcMode == "Standard Deviation" ? stdevAbs : ta.vwap * 0.01
    upperBandValue := ta.vwap + bandBasis * bandMult
    lowerBandValue := ta.vwap - bandBasis * bandMult

// =============================================
// PLOTS / VYKRESLENIE
// Farba, hrúbka a typ čiary sa nastavujú v Style tab
// =============================================

// MA
plot(ma1, "MA 1", color = #FF6D00, linewidth = 2)
plot(ma2, "MA 2", color = #2962FF, linewidth = 2)
plot(ma3, "MA 3", color = #9C27B0, linewidth = 1)
plot(ma4, "MA 4", color = #E91E63, linewidth = 1)

// VWAP
plot(vwapValue, "VWAP", color = #2196F3, linewidth = 2)

// VWAP Band
displayBand = show_band ? display.all : display.none
upperBand = plot(upperBandValue, "Upper Band", color = #26A69A, display = displayBand)
lowerBand = plot(lowerBandValue, "Lower Band", color = #26A69A, display = displayBand)
fill(upperBand, lowerBand, color = color.new(#26A69A, 90), title = "Band Fill", display = displayBand)
